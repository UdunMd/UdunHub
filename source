-- Load UI
loadstring(game:HttpGet('https://raw.githubusercontent.com/GhostPlayer352/UI-Library/refs/heads/main/Ghost%20Gui'))()
game.CoreGui.GhostGui.MainFrame.Title.Text = "Tornado & Fly GUI"

local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local root = char:WaitForChild("HumanoidRootPart")
local humanoid = char:WaitForChild("Humanoid")

-- SETTINGS
local tornadoOn = false
local tornadoSpeed = 5
local tornadoRadius = 10

local flyOn = false
local flySpeed = 50

-- BODY VELOCITY (FLY)
local bodyVelocity

-- MAIN LOOP (gabungan tornado + fly)
task.spawn(function()
    while true do
        task.wait()

        if root then
            -- TORNADO
            if tornadoOn then
                local t = tick()
                local x = math.cos(t * tornadoSpeed) * tornadoRadius
                local z = math.sin(t * tornadoSpeed) * tornadoRadius
                root.Velocity = Vector3.new(x, 50, z)
            end

            -- FLY
            if flyOn then
                if not bodyVelocity then
                    bodyVelocity = Instance.new("BodyVelocity")
                    bodyVelocity.MaxForce = Vector3.new(1e5,1e5,1e5)
                    bodyVelocity.Parent = root
                end

                local moveDir = humanoid.MoveDirection
                bodyVelocity.Velocity = moveDir * flySpeed + Vector3.new(0, flySpeed/2, 0)
            else
                if bodyVelocity then
                    bodyVelocity:Destroy()
                    bodyVelocity = nil
                end
            end
        end
    end
end)

-- ================= UI =================

-- TORNADO TOGGLE
AddContent("Toogle", "Tornado ON/OFF", [[
tornadoOn = not tornadoOn
]])

-- TORNADO SPEED
local speedBox = AddContent("TextBox","Tornado Speed")
speedBox:GetPropertyChangedSignal("Text"):Connect(function()
    local val = tonumber(speedBox.Text)
    if val then
        tornadoSpeed = val
    end
end)

-- TORNADO RADIUS
local radiusBox = AddContent("TextBox","Tornado Radius")
radiusBox:GetPropertyChangedSignal("Text"):Connect(function()
    local val = tonumber(radiusBox.Text)
    if val then
        tornadoRadius = val
    end
end)

-- FLY TOGGLE
AddContent("Toogle", "Fly ON/OFF", [[
flyOn = not flyOn
]])

-- FLY SPEED
local flyBox = AddContent("TextBox","Fly Speed")
flyBox:GetPropertyChangedSignal("Text"):Connect(function()
    local val = tonumber(flyBox.Text)
    if val then
        flySpeed = val
    end
end)

-- LABEL
local label = AddContent("TextLabel")
label.Text = "Tornado + Fly Script Ready"
