-- Load Rayfield
local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/shlexware/Rayfield/main/source'))()

-- Window
local Window = Rayfield:CreateWindow({
    Name = "Tornado Controller",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "by ChatGPT",
    ConfigurationSaving = {
        Enabled = true
    }
})

-- Tab
local Tab = Window:CreateTab("Tornado", 4483362458)

-- Variabel
local tornadoActive = false
local radius = 30
local height = 20
local speed = 2

-- Function Tornado
local function startTornado()
    local player = game.Players.LocalPlayer
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")

    while tornadoActive do
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Anchored == false then
                local distance = (obj.Position - root.Position).Magnitude
                if distance < radius then
                    local angle = tick() * speed
                    local x = math.cos(angle) * distance
                    local z = math.sin(angle) * distance
                    local y = math.sin(tick()*2) * height

                    obj.Velocity = Vector3.new(x, y + 50, z)
                end
            end
        end
        task.wait()
    end
end

-- Toggle Tornado
Tab:CreateToggle({
    Name = "Aktifkan Tornado",
    CurrentValue = false,
    Callback = function(Value)
        tornadoActive = Value
        if Value then
            task.spawn(startTornado)
        end
    end
})

-- Slider Radius
Tab:CreateSlider({
    Name = "Radius",
    Range = {10, 100},
    Increment = 5,
    CurrentValue = radius,
    Callback = function(Value)
        radius = Value
    end
})

-- Slider Height
Tab:CreateSlider({
    Name = "Height",
    Range = {10, 100},
    Increment = 5,
    CurrentValue = height,
    Callback = function(Value)
        height = Value
    end
})

-- Slider Speed
Tab:CreateSlider({
    Name = "Speed",
    Range = {1, 10},
    Increment = 1,
    CurrentValue = speed,
    Callback = function(Value)
        speed = Value
    end
})

-- Notify
Rayfield:Notify({
    Title = "Loaded!",
    Content = "Tornado siap digunakan 🌪️",
    Duration = 4
})
