local fly = false
local bv

AddContent("Toogle", "Fly", [[
fly = true
bv = Instance.new("BodyVelocity")
bv.MaxForce = Vector3.new(999999,999999,999999)
bv.Parent = root

while fly do
    bv.Velocity = workspace.CurrentCamera.CFrame.LookVector * 60
    task.wait()
end
]], [[
fly = false
if bv then bv:Destroy() end
]])

--------------------------------------------------
-- 🕳️ BLACK HOLE
--------------------------------------------------
local blackholeActive = false
local hole

AddContent("Toogle", "Black Hole", [[
blackholeActive = true

hole = Instance.new("Part")
hole.Shape = Enum.PartType.Ball
hole.Size = Vector3.new(6,6,6)
hole.Material = Enum.Material.Neon
hole.BrickColor = BrickColor.new("Really black")
hole.Anchored = true
hole.CanCollide = false
hole.Parent = workspace

while blackholeActive do
    hole.Position = root.Position + Vector3.new(0,5,0)

    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and v ~= hole then
            local dist = (v.Position - hole.Position).Magnitude
            if dist < 50 then
                v.Velocity = (hole.Position - v.Position).Unit * 120
            end
        end
    end

    task.wait()
end

hole:Destroy()
]], [[
blackholeActive = false
if hole then hole:Destroy() end
]])

