--[[
    Custom Script: Spin & Fly
    Library: Compkiller UI
]]

local Compkiller = loadstring(game:HttpGet("https://raw.githubusercontent.com/4lpaca-pin/CompKiller/refs/heads/main/src/source.luau"))();

-- Setup Config
local ConfigManager = Compkiller:ConfigManager({
	Directory = "Compkiller-UI",
	Config = "Movement-Configs"
});

-- Loading
Compkiller:Loader("rbxassetid://120245531583106" , 2.0).yield();

-- Creating Window
local Window = Compkiller.new({
	Name = "PREMIUM CHEATS",
	Keybind = "LeftAlt",
	Logo = "rbxassetid://120245531583106",
	TextSize = 15,
});

-- Variables for Features
local Player = game.Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local RunService = game:GetService("RunService")

local Flying = false
local Spinning = false
local FlySpeed = 50
local SpinSpeed = 20

-- Update character reference when respawning
Player.CharacterAdded:Connect(function(char)
    Character = char
end)

-- Tab Category
Window:DrawCategory({ Name = "Main Features" });

local MainTab = Window:DrawTab({
	Name = "Movement",
	Icon = "Zap",
	EnableScrolling = true
});

local MoveSection = MainTab:DrawSection({
	Name = "Player Hacks",
	Position = 'left'	
});

--- [[ SPIN FEATURE ]] ---
MoveSection:AddToggle({
	Name = "Spin Character",
	Flag = "spin_toggle",
	Default = false,
	Callback = function(state)
		Spinning = state
		if Spinning then
			task.spawn(function()
				while Spinning do
					if Character and Character:FindFirstChild("HumanoidRootPart") then
						Character.HumanoidRootPart.CFrame = Character.HumanoidRootPart.CFrame * CFrame.Angles(0, math.rad(SpinSpeed), 0)
					end
					task.wait()
				end
			end)
		end
	end,
});

MoveSection:AddSlider({
	Name = "Spin Speed",
	Min = 0,
	Max = 100,
	Default = 20,
	Flag = "spin_speed",
	Callback = function(v) SpinSpeed = v end
});

--- [[ FLY FEATURE ]] ---
MoveSection:AddToggle({
	Name = "Fly Mode",
	Flag = "fly_toggle",
	Default = false,
	Callback = function(state)
		Flying = state
		local Humanoid = Character:FindFirstChildOfClass("Humanoid")
		
		if Flying then
			local BodyGyro = Instance.new("BodyGyro", Character.HumanoidRootPart)
			local BodyVelocity = Instance.new("BodyVelocity", Character.HumanoidRootPart)
			
			BodyGyro.P = 9e4
			BodyGyro.maxTorque = Vector3.new(9e9, 9e9, 9e9)
			BodyGyro.cframe = Character.HumanoidRootPart.CFrame
			
			BodyVelocity.velocity = Vector3.new(0, 0.1, 0)
			BodyVelocity.maxForce = Vector3.new(9e9, 9e9, 9e9)
			
			task.spawn(function()
				while Flying do
					RunService.RenderStepped:Wait()
					local Camera = workspace.CurrentCamera
					local MoveDirection = Vector3.new(0,0,0)
					
					-- Sederhana: Terbang mengikuti arah kamera
					if Humanoid.MoveDirection.Magnitude > 0 then
						BodyVelocity.velocity = Camera.CFrame.LookVector * FlySpeed
					else
						BodyVelocity.velocity = Vector3.new(0, 0.1, 0)
					end
					BodyGyro.cframe = Camera.CFrame
				end
				BodyGyro:Destroy()
				BodyVelocity:Destroy()
			end)
		end
	end,
});

MoveSection:AddSlider({
	Name = "Fly Speed",
	Min = 10,
	Max = 300,
	Default = 50,
	Flag = "fly_speed",
	Callback = function(v) FlySpeed = v end
});

-- Config Tab Setup
local ConfigUI = Window:DrawConfig({
	Name = "Settings",
	Icon = "settings",
	Config = ConfigManager
});

ConfigUI:Init();
