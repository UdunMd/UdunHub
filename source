-- Load UI
loadstring(game:HttpGet('https://raw.githubusercontent.com/GhostPlayer352/UI-Library/refs/heads/main/Ghost%20Gui'))()
game.CoreGui.GhostGui.MainFrame.Title.Text = "Tornado Controller"

-- CONFIG
local tornado = nil
local running = false
local speed = 5 -- default speed

-- FUNCTION BUAT TORNADO
local function createTornado()
    if tornado then tornado:Destroy() end

    tornado = Instance.new("Part")
    tornado.Size = Vector3.new(5, 20, 5)
    tornado.Anchored = true
    tornado.CanCollide = false
    tornado.Material = Enum.Material.Neon
    tornado.Color = Color3.fromRGB(170, 170, 255)
    tornado.Name = "Tornado"
    tornado.Parent = workspace

    -- posisi di depan player
    local char = game.Players.LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        tornado.Position = char.HumanoidRootPart.Position + Vector3.new(0, 0, -10)
    end

    -- efek muter
    task.spawn(function()
        while running and tornado do
            tornado.CFrame = tornado.CFrame * CFrame.Angles(0, math.rad(speed), 0)
            task.wait()
        end
    end)
end

-- BUTTON ON/OFF
AddContent("Toogle", "Tornado ON/OFF", [[
running = not running

if running then
    createTornado()
else
    if tornado then
        tornado:Destroy()
        tornado = nil
    end
end
]])

-- TEXTBOX UNTUK ATUR SPEED
local SpeedBox = AddContent("TextBox","Set Speed (angka)")

SpeedBox:GetPropertyChangedSignal("Text"):Connect(function()
    local val = tonumber(SpeedBox.Text)
    if val then
        speed = val
    end
end)

