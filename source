-- Load UI
loadstring(game:HttpGet('https://raw.githubusercontent.com/GhostPlayer352/UI-Library/refs/heads/main/Ghost%20Gui'))()
game.CoreGui.GhostGui.MainFrame.Title.Text = "Tornado Combo"

-- Variables
local spinning = false
local speed = 5
local radius = 10

-- Main Tornado Function
local function startTornado()
    local player = game.Players.LocalPlayer
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    spinning = true

    task.spawn(function()
        while spinning do
            for i = 0, 360, speed do
                if not spinning then break end

                local angle = math.rad(i)
                local offset = Vector3.new(math.cos(angle)*radius, 0, math.sin(angle)*radius)

                -- Spin Character
                hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(speed*10), 0) + offset

                -- Tornado Effect (pull items)
                for _,v in pairs(workspace:GetDescendants()) do
                    if v:IsA("BasePart") and not v.Anchored and v ~= hrp then
                        local dist = (v.Position - hrp.Position).Magnitude
                        if dist < radius * 3 then
                            local dir = (hrp.Position - v.Position).Unit
                            
                            -- Tarik + putar + angkat
                            v.Velocity =
                                dir * (speed * 15) +
                                Vector3.new(
                                    math.cos(angle) * speed * 5,
                                    speed * 6,
                                    math.sin(angle) * speed * 5
                                )
                        end
                    end
                end

                task.wait()
            end
        end
    end)
end

local function stopTornado()
    spinning = false
end

-- UI BUTTONS
AddContent("TextButton", "Start Tornado", [[
startTornado()
]])

AddContent("TextButton", "Stop Tornado", [[
stopTornado()
]])

-- SPEED CONTROL
local SpeedBox = AddContent("TextBox","Set Speed")
SpeedBox:GetPropertyChangedSignal("Text"):Connect(function()
    local val = tonumber(SpeedBox.Text)
    if val then
        speed = val
    end
end)

-- RADIUS CONTROL
local RadiusBox = AddContent("TextBox","Set Radius")
RadiusBox:GetPropertyChangedSignal("Text"):Connect(function()
    local val = tonumber(RadiusBox.Text)
    if val then
        radius = val
    end
end)

-- TOGGLE
AddContent("Toogle", "Enable Tornado", [[
startTornado()
]])

-- SWITCH
AddContent("Switch", "Tornado Switch", [[
startTornado()
]],[[
stopTornado()
]])

